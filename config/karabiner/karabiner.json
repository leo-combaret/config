{
    "global": { "show_in_menu_bar": false },
    "profiles": [
        {
            "complex_modifications": {
                "parameters": { "basic.to_if_alone_timeout_milliseconds": 300 },
                "rules": [
                    {
                        "description": "In Zed, tap left command alone to send F18",
                        "manipulators": [
                            {
                                "conditions": [
                                    {
                                        "bundle_identifiers": [
                                            "^dev\\.zed\\.Zed$"
                                        ],
                                        "type": "frontmost_application_if"
                                    }
                                ],
                                "from": {
                                    "key_code": "left_command",
                                    "modifiers": { "optional": ["any"] }
                                },
                                "to": [{ "key_code": "left_command" }],
                                "to_if_alone": [{ "key_code": "f18" }],
                                "type": "basic"
                            }
                        ]
                    },
                    {
                        "description": "Switch Zed Mistral worktrees with right command + 1-4",
                        "manipulators": [
                            {
                                "from": {
                                    "key_code": "1",
                                    "modifiers": {
                                        "mandatory": ["right_command"],
                                        "optional": ["caps_lock"]
                                    }
                                },
                                "to": [
                                    {
                                        "shell_command": "$HOME/.agents/config/bin/zed-mistral-switch dashboard",
                                        "repeat": false
                                    }
                                ],
                                "type": "basic"
                            },
                            {
                                "from": {
                                    "key_code": "2",
                                    "modifiers": {
                                        "mandatory": ["right_command"],
                                        "optional": ["caps_lock"]
                                    }
                                },
                                "to": [
                                    {
                                        "shell_command": "$HOME/.agents/config/bin/zed-mistral-switch seattle",
                                        "repeat": false
                                    }
                                ],
                                "type": "basic"
                            },
                            {
                                "from": {
                                    "key_code": "3",
                                    "modifiers": {
                                        "mandatory": ["right_command"],
                                        "optional": ["caps_lock"]
                                    }
                                },
                                "to": [
                                    {
                                        "shell_command": "$HOME/.agents/config/bin/zed-mistral-switch budapest",
                                        "repeat": false
                                    }
                                ],
                                "type": "basic"
                            },
                            {
                                "from": {
                                    "key_code": "4",
                                    "modifiers": {
                                        "mandatory": ["right_command"],
                                        "optional": ["caps_lock"]
                                    }
                                },
                                "to": [
                                    {
                                        "shell_command": "$HOME/.agents/config/bin/zed-mistral-switch dakar",
                                        "repeat": false
                                    }
                                ],
                                "type": "basic"
                            }
                        ]
                    }
                ]
            },
            "name": "Default profile",
            "selected": true,
            "virtual_hid_keyboard": {
                "keyboard_type": "ansi",
                "keyboard_type_v2": "ansi"
            }
        }
    ]
}
